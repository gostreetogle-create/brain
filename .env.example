OPENROUTER_API_KEY=sk-or-v1-твой_ключ_здесь

# Модель для анализа документов (бесплатно)
EXTRACTOR_MODEL=google/gemma-4-26b-a4b-it:free

# Модель для ответов в чате (бесплатно, 1M контекст)
CHAT_MODEL=deepseek/deepseek-v4-flash:free

# Максимальный размер файла для обработки (в MB)
MAX_FILE_SIZE_MB=50

# Папки (относительно brain_data/)
INBOX_DIR=brain_data/inbox
PROCESSED_DIR=brain_data/processed
ERRORS_DIR=brain_data/errors
MEMORY_FILE=brain_data/brain.jsonl
INDEX_FILE=brain_data/index.faiss
